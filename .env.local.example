# Copy to .env.local and fill in values

# Google OAuth (https://console.cloud.google.com → APIs → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # generate with: openssl rand -base64 32

# Vercel Postgres (auto-set when you create a Vercel Postgres store)
DATABASE_URL=

# Slack (https://api.slack.com/apps → create app → Bot Token Scopes: channels:history, channels:read, users:read)
SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# Vercel Cron Secret (optional — protects the weekly Slack sync cron)
CRON_SECRET=  # generate with: openssl rand -base64 32
