# Copy to .env.local and fill in values (or run: npm run setup)

# Google OAuth — create credentials: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google (and your production URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth (npm run setup will generate NEXTAUTH_SECRET for you)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Vercel Postgres (auto-set when you create a Vercel Postgres store)
DATABASE_URL=

# Slack — create app: https://api.slack.com/apps → Bot scopes: channels:history, channels:read, users:read
SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# Optional: protects weekly Slack sync cron (npm run setup will generate)
CRON_SECRET=
